# Conexão com o Banco de Dados
# Substitua com a URI que você copiou do painel do Supabase (Project Settings > Database)

# Controle de Ambiente (Boa prática de engenharia para o código saber onde está rodando)
ENVIRONMENT=development

# ─── Banco de dados (Supabase / PostgreSQL) ───────────────────────────────────
# Encontre em: Supabase → Project Settings → Database → Connection string → URI
# Troque [YOUR-PASSWORD] pela senha do projeto
DATABASE_URL=postgresql://postgres.whlpwdphkrkczdqarzil:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.whlpwdphkrkczdqarzil:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://<projeto>.supabase.co
SUPABASE_KEY=<sua-anon-ou-service-role-key>

# URI completa para SQLAlchemy (DDL + leitura direta)
# Formato: dialect+driver://user:password@host:port/database
DB_URI_DDL=postgresql+psycopg2://user:password@host:5432/dbname

# ─── Groq ─────────────────────────────────────────────────────────────────────
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Modelo Groq (opcional — padrão: llama-3.1-8b-instant) ───────────────────
# Opções gratuitas: llama-3.1-8b-instant | llama-3.3-70b-versatile | gemma2-9b-it
# GROQ_MODEL=llama-3.1-8b-instant

#─── Ollama (para o modo bulk)─────────────────────────────────────────────────────────
# Instale em [ollama.com/download](https://ollama.com/download)
